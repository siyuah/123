{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/v2.9-companion-bound-r1/core_objects.schema.json",
  "title": "Paperclip × Dark Factory V2.9 Core Objects",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/ExecutionCapabilityLease"
    },
    {
      "$ref": "#/$defs/ArtifactCertification"
    },
    {
      "$ref": "#/$defs/LineageEdge"
    },
    {
      "$ref": "#/$defs/ConsumptionWaiver"
    },
    {
      "$ref": "#/$defs/ShadowCompareRecord"
    },
    {
      "$ref": "#/$defs/ParkRecord"
    },
    {
      "$ref": "#/$defs/RehydrationToken"
    },
    {
      "$ref": "#/$defs/ManualGateDefinition"
    }
  ],
  "$defs": {
    "IsoDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "ProtocolReleaseTag": {
      "type": "string",
      "enum": [
        "v2.9-companion-bound-r1"
      ]
    },
    "Capability": {
      "type": "string",
      "enum": [
        "fs_read_workspace",
        "fs_write_workspace",
        "fs_read_restricted_ref_via_gateway",
        "process_spawn_local",
        "network_read_allowlist",
        "network_write_brokered_only",
        "secret_read_named",
        "external_api_via_adapter_only",
        "package_install_mirror_only",
        "ipc_local_only"
      ]
    },
    "ArtifactCertificationState": {
      "type": "string",
      "enum": [
        "tentative",
        "certified",
        "reopened",
        "revoked",
        "quarantined",
        "superseded"
      ]
    },
    "DependencyConsumptionPolicy": {
      "type": "string",
      "enum": [
        "certified_only",
        "tentative_allowed_internal",
        "tentative_allowed_with_waiver"
      ]
    },
    "InputDependencyState": {
      "type": "string",
      "enum": [
        "clean",
        "tentative_upstream",
        "reopened_upstream",
        "revoked_upstream",
        "manually_waived"
      ]
    },
    "ProfileConformanceStatus": {
      "type": "string",
      "enum": [
        "conformant",
        "exceeded_declared",
        "broker_bypass_attempted",
        "unverifiable"
      ]
    },
    "CapsuleHealth": {
      "type": "string",
      "enum": [
        "healthy",
        "preflight_red",
        "poisoned"
      ]
    },
    "ManualGateType": {
      "type": "string",
      "enum": [
        "manual_approval_required",
        "manual_evidence_access_required",
        "manual_adjudication_required",
        "manual_risk_acceptance_required",
        "manual_recovery_required",
        "manual_external_followup_required"
      ]
    },
    "RunState": {
      "type": "string",
      "enum": [
        "requested",
        "validating",
        "planning",
        "executing",
        "waiting_input",
        "waiting_approval",
        "parked_manual",
        "blocked",
        "finalizing",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "ReasonCode": {
      "type": "string",
      "enum": [
        "approval_required",
        "execution_starts",
        "manual_gate_triggered",
        "operator_sla_timeout",
        "rehydrate_approved",
        "runtime_audit_coverage_insufficient",
        "capability_observation_exceeded_declared",
        "broker_bypass_attempted_detected",
        "revoked_upstream_waiver_cannot_allow_primary_write",
        "capsule_poisoned_retry_blocked",
        "schema_write_fence_violation"
      ]
    },
    "ParkReasonCode": {
      "type": "string",
      "enum": [
        "operator_sla_timeout"
      ]
    },
    "ExecutionSuspensionState": {
      "type": "string",
      "enum": [
        "none",
        "frozen",
        "parked_manual",
        "quarantined_input"
      ]
    },
    "ExecutionCapabilityLease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executorSessionId",
        "executionCapabilityLeaseId",
        "protocolReleaseTag",
        "declaredCapabilitySet",
        "grantedCapabilitySet",
        "observedCapabilitySet",
        "capabilityLeaseIssuedAt",
        "capabilityLeaseExpiresAt",
        "profileConformanceStatus",
        "runtimeAuditRef"
      ],
      "properties": {
        "executorSessionId": {
          "type": "string"
        },
        "executionCapabilityLeaseId": {
          "type": "string"
        },
        "protocolReleaseTag": {
          "$ref": "#/$defs/ProtocolReleaseTag"
        },
        "traceId": {
          "type": "string"
        },
        "declaredCapabilitySet": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Capability"
          },
          "uniqueItems": true
        },
        "grantedCapabilitySet": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Capability"
          },
          "uniqueItems": true
        },
        "observedCapabilitySet": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Capability"
          },
          "uniqueItems": true
        },
        "sandboxBoundaryProfile": {
          "type": "string"
        },
        "networkPolicyProfile": {
          "type": "string"
        },
        "secretAccessProfile": {
          "type": "string"
        },
        "egressBrokerMode": {
          "type": "string"
        },
        "capabilityLeaseIssuedAt": {
          "$ref": "#/$defs/IsoDateTime"
        },
        "capabilityLeaseExpiresAt": {
          "$ref": "#/$defs/IsoDateTime"
        },
        "profileConformanceStatus": {
          "$ref": "#/$defs/ProfileConformanceStatus"
        },
        "runtimeAuditRef": {
          "type": "string"
        }
      }
    },
    "ArtifactCertification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "producerRunId",
        "producerAttemptId",
        "artifactDigest",
        "artifactCertificationState",
        "lineageParentArtifactIds",
        "revocationEpoch",
        "downstreamConsumptionClass",
        "protocolReleaseTag",
        "traceId"
      ],
      "properties": {
        "artifactId": {
          "type": "string"
        },
        "producerRunId": {
          "type": "string"
        },
        "producerAttemptId": {
          "type": "string"
        },
        "artifactDigest": {
          "type": "string"
        },
        "artifactCertificationState": {
          "$ref": "#/$defs/ArtifactCertificationState"
        },
        "lineageParentArtifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "revocationEpoch": {
          "type": "integer",
          "minimum": 0
        },
        "downstreamConsumptionClass": {
          "type": "string"
        },
        "protocolReleaseTag": {
          "$ref": "#/$defs/ProtocolReleaseTag"
        },
        "traceId": {
          "type": "string"
        },
        "triggeringEvidenceRef": {
          "type": "string"
        }
      }
    },
    "LineageEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edgeId",
        "parentArtifactId",
        "consumerRunId",
        "consumedArtifactIds",
        "dependencyConsumptionPolicy",
        "inputDependencyState",
        "protocolReleaseTag"
      ],
      "properties": {
        "edgeId": {
          "type": "string"
        },
        "parentArtifactId": {
          "type": "string"
        },
        "consumerRunId": {
          "type": "string"
        },
        "consumedArtifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "dependencyConsumptionPolicy": {
          "$ref": "#/$defs/DependencyConsumptionPolicy"
        },
        "inputDependencyState": {
          "$ref": "#/$defs/InputDependencyState"
        },
        "protocolReleaseTag": {
          "$ref": "#/$defs/ProtocolReleaseTag"
        },
        "traceId": {
          "type": "string"
        },
        "consumptionWaiverRef": {
          "type": "string"
        },
        "blockNewHighRiskWrites": {
          "type": "boolean"
        }
      }
    },
    "ConsumptionWaiver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "waiverId",
        "artifactId",
        "approvedBy",
        "approvedAt",
        "expiresAt",
        "allowedConsumerScope",
        "allowedConsumptionPolicy",
        "allowedEffectSafetyCeiling",
        "maxFanOut",
        "reasonCode",
        "protocolReleaseTag"
      ],
      "properties": {
        "waiverId": {
          "type": "string"
        },
        "artifactId": {
          "type": "string"
        },
        "approvedBy": {
          "type": "string"
        },
        "approvedAt": {
          "$ref": "#/$defs/IsoDateTime"
        },
        "expiresAt": {
          "$ref": "#/$defs/IsoDateTime"
        },
        "allowedConsumerScope": {
          "type": "string"
        },
        "allowedConsumptionPolicy": {
          "$ref": "#/$defs/DependencyConsumptionPolicy"
        },
        "allowedEffectSafetyCeiling": {
          "type": "string"
        },
        "maxFanOut": {
          "type": "integer",
          "minimum": 1
        },
        "reasonCode": {
          "$ref": "#/$defs/ReasonCode"
        },
        "protocolReleaseTag": {
          "$ref": "#/$defs/ProtocolReleaseTag"
        },
        "traceId": {
          "type": "string"
        }
      }
    },
    "ShadowCompareRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sampleRunId",
        "blastRadiusClass",
        "protectedFlow",
        "structuredDecisionDiverged",
        "deadlineCrossed",
        "timingBucketShift",
        "protocolReleaseTag"
      ],
      "properties": {
        "sampleRunId": {
          "type": "string"
        },
        "blastRadiusClass": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "irreversible"
          ]
        },
        "protectedFlow": {
          "type": "boolean"
        },
        "structuredDecisionDiverged": {
          "type": "boolean"
        },
        "deadlineCrossed": {
          "type": "boolean"
        },
        "timingBucketShift": {
          "type": "string",
          "enum": [
            "0",
            "1",
            "2plus"
          ]
        },
        "protocolReleaseTag": {
          "$ref": "#/$defs/ProtocolReleaseTag"
        },
        "traceId": {
          "type": "string"
        }
      }
    },
    "ParkRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parkRecordId",
        "runId",
        "attemptId",
        "manualGateType",
        "parkedAt",
        "parkReasonCode",
        "executionSuspensionState",
        "truthObligationRef",
        "rehydrateTokenRef",
        "protocolReleaseTag",
        "traceId"
      ],
      "properties": {
        "parkRecordId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "attemptId": {
          "type": "string"
        },
        "manualGateType": {
          "$ref": "#/$defs/ManualGateType"
        },
        "parkedAt": {
          "$ref": "#/$defs/IsoDateTime"
        },
        "parkReasonCode": {
          "$ref": "#/$defs/ParkReasonCode"
        },
        "executionSuspensionState": {
          "$ref": "#/$defs/ExecutionSuspensionState"
        },
        "truthObligationRef": {
          "type": "string"
        },
        "rehydrateTokenRef": {
          "type": "string"
        },
        "resourceReleaseEvidenceRef": {
          "type": "string"
        },
        "preserveEvidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "protocolReleaseTag": {
          "$ref": "#/$defs/ProtocolReleaseTag"
        },
        "traceId": {
          "type": "string"
        }
      }
    },
    "RehydrationToken": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rehydrateTokenRef",
        "runId",
        "parkRecordId",
        "issuedAt",
        "expiresAt",
        "requirements",
        "status",
        "protocolReleaseTag"
      ],
      "properties": {
        "rehydrateTokenRef": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "parkRecordId": {
          "type": "string"
        },
        "issuedAt": {
          "$ref": "#/$defs/IsoDateTime"
        },
        "expiresAt": {
          "$ref": "#/$defs/IsoDateTime"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": [
            "issued",
            "consumed",
            "expired",
            "revoked"
          ]
        },
        "consumedAt": {
          "$ref": "#/$defs/IsoDateTime"
        },
        "consumedBy": {
          "type": "string"
        },
        "newAttemptId": {
          "type": "string"
        },
        "protocolReleaseTag": {
          "$ref": "#/$defs/ProtocolReleaseTag"
        },
        "traceId": {
          "type": "string"
        }
      }
    },
    "ManualGateDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manualGateType",
        "ownerRole",
        "minimumEvidenceSet",
        "allowedActions",
        "defaultSlaSec",
        "escalationTarget",
        "parkResourcesAfterSec",
        "rehydrationRequirements",
        "protocolReleaseTag"
      ],
      "properties": {
        "manualGateType": {
          "$ref": "#/$defs/ManualGateType"
        },
        "ownerRole": {
          "type": "string"
        },
        "minimumEvidenceSet": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "allowedActions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "defaultSlaSec": {
          "type": "integer",
          "minimum": 1
        },
        "escalationTarget": {
          "type": "string"
        },
        "parkResourcesAfterSec": {
          "type": "integer",
          "minimum": 0
        },
        "rehydrationRequirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "consumesTentativeInputAllowed": {
          "type": "boolean"
        },
        "protocolReleaseTag": {
          "$ref": "#/$defs/ProtocolReleaseTag"
        }
      }
    }
  }
}
